+function buildGithubDirectPrompt(args) {
+  if (!/^[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+$/.test(args.githubRepository)) {
+    throw new Error('GitHub direct mode requires --github-repository owner/repository.');
+  }
