#!/usr/bin/env bash
set -Eeuo pipefail

project=${PSEUDO_CODEX_JOB_WORKSPACE:-/home/ubuntu/chatgpt-projects/request-console}
canonical_project=/home/ubuntu/chatgpt-projects/request-console
console_app=/opt/pseudo-codex-console/app.js
validator_root=/usr/local/lib/pseudo-codex-console-deploy
dispatcher_runtime=/home/ubuntu/.local/lib/pseudo-codex/dispatcher.py
agent_runtime_root=/home/ubuntu/chatgpt-browser-agent
agent_wrapper=/usr/local/bin/chatgpt-browser-agent
state_root=/home/ubuntu/.local/state/pseudo-codex
timestamp=$(date +%Y%m%d-%H%M%S)
backup_root="$state_root/deploy-request-console-$timestamp"
manifest_path="$backup_root/manifest.tsv"
revision_path="$state_root/request-console.deployed-revision"

declare -a writable_specs=(
  "$project/app.js|$console_app|0644|console"
  "$project/dispatcher/dispatcher.py|$dispatcher_runtime|0644|dispatcher"
  "$project/agent/agent.js|$agent_runtime_root/agent.js|0644|agent"
  "$project/agent/chatgpt.js|$agent_runtime_root/chatgpt.js|0644|agent"
  "$project/agent/ws-decode.js|$agent_runtime_root/ws-decode.js|0644|agent"
  "$project/systemd/pseudo-codex-dispatcher.service.d/20-browser-pool.conf|/home/ubuntu/.config/systemd/user/pseudo-codex-dispatcher.service.d/20-browser-pool.conf|0644|dispatcher"
)

declare -a required_mirrors=(
  "$project/deploy/deploy-request-console|/usr/local/libexec/pseudo-codex-deploy-request-console"
  "$project/scripts/chatgpt-browser-agent|$agent_wrapper"
  "$project/check.js|$validator_root/check.js"
  "$project/deploy/verify-live.js|$validator_root/verify-live.js"
)

console_changed=0
dispatcher_changed=0
agent_changed=0
copied_count=0
dispatcher_restart_scheduled=0
app_deployed=0
agent_update_pending=0

resolved_project=$(realpath -- "$project")
resolved_canonical=$(realpath -- "$canonical_project")
if [[ "$resolved_project" != "$resolved_canonical" ]]; then
  printf '%s\n' "AUTO_DEPLOY_FAILED request-console deploy source must be canonical Ubuntu workspace: $resolved_canonical"
  exit 2
fi
branch=$(git -C "$project" symbolic-ref --quiet --short HEAD 2>/dev/null || true)
if [[ "$branch" != main ]]; then
  printf '%s\n' "AUTO_DEPLOY_FAILED request-console deploy source must be main, actual=${branch:-detached}"
  exit 2
fi
if [[ -n $(git -C "$project" status --porcelain=v1 --untracked-files=all) ]]; then
  printf '%s\n' 'AUTO_DEPLOY_FAILED request-console main workspace is dirty'
  exit 2
fi
local_revision=$(git -C "$project" rev-parse HEAD)
remote_revision=$(git -C "$project" rev-parse refs/remotes/origin/main 2>/dev/null || true)
if [[ -z "$remote_revision" || "$local_revision" != "$remote_revision" ]]; then
  printf '%s\n' "AUTO_DEPLOY_FAILED request-console main must equal origin/main local=$local_revision remote=${remote_revision:-missing}"
  exit 2
fi

mkdir -p "$state_root" "$backup_root"
touch "$manifest_path"
exec 9>"$state_root/deploy-request-console.lock"
if ! flock -n 9; then
  printf '%s\n' 'AUTO_DEPLOY_FAILED another deployment is already running'
  exit 75
fi

current_revision=$(git -C "$project" rev-parse HEAD 2>/dev/null || printf 'workspace-no-git')
deployed_revision=$(cat "$revision_path" 2>/dev/null || true)

ensure_parent_dir() {
  install -d -- "$(dirname -- "$1")"
}

compare_files() {
  local src=$1
  local dest=$2
  [[ -e "$dest" ]] || return 1
  cmp -s -- "$src" "$dest"
}

require_executable() {
  local path=$1
  [[ -x "$path" ]] || {
    printf '%s\n' "AUTO_DEPLOY_FAILED required executable is not executable: $path"
    exit 2
  }
}

backup_target() {
  local dest=$1
  local backup="$backup_root${dest}"
  ensure_parent_dir "$backup"
  if [[ -e "$dest" || -L "$dest" ]]; then
    cp -a --no-dereference -- "$dest" "$backup"
    printf '%s\t%s\t%s\n' "$dest" "$backup" restore >> "$manifest_path"
  else
    printf '%s\t%s\t%s\n' "$dest" "$backup" delete >> "$manifest_path"
  fi
}

install_target() {
  local src=$1
  local dest=$2
  local mode=$3
  ensure_parent_dir "$dest"
  install -m "$mode" -- "$src" "$dest"
}

restore_targets() {
  [[ -s "$manifest_path" ]] || return 0
  while IFS=$'\t' read -r dest backup action; do
    if [[ "$action" == "restore" ]]; then
      ensure_parent_dir "$dest"
      cp -a --no-dereference -- "$backup" "$dest"
    else
      rm -f -- "$dest"
    fi
  done < <(tac "$manifest_path")
}

schedule_dispatcher_restart() {
  if ((dispatcher_restart_scheduled)); then
    return 0
  fi
  local restart_unit="pseudo-codex-dispatcher-restart-${timestamp}-$$"
  systemctl --user daemon-reload
  systemd-run --user --quiet --collect \
    --unit "$restart_unit" \
    --on-active=2s \
    /usr/bin/systemctl --user restart pseudo-codex-dispatcher.service
  dispatcher_restart_scheduled=1
}

rollback() {
  status=$?
  trap - ERR
  restore_targets || true
  if ((agent_changed)); then
    systemctl --user restart chatgpt-browser-agent.service >/dev/null 2>&1 || true
  fi
  if ((console_changed)); then
    sudo -n /usr/bin/systemctl restart pseudo-codex-console.service >/dev/null 2>&1 || true
  fi
  if ((dispatcher_changed)); then
    schedule_dispatcher_restart || true
  fi
  printf '%s\n' "AUTO_DEPLOY_ROLLED_BACK status=$status backup=$backup_root"
  exit "$status"
}
trap rollback ERR

if ! sudo -n /usr/bin/systemctl is-active pseudo-codex-console.service >/dev/null 2>&1; then
  printf '%s\n' 'AUTO_DEPLOY_FAILED missing passwordless sudo for pseudo-codex-console.service'
  exit 2
fi

for spec in "${required_mirrors[@]}"; do
  IFS='|' read -r src dest <<<"$spec"
  [[ -f "$src" ]] || {
    printf '%s\n' "AUTO_DEPLOY_FAILED missing source: $src"
    exit 2
  }
  compare_files "$src" "$dest" || {
    printf '%s\n' "AUTO_DEPLOY_FAILED bootstrap mismatch: $dest"
    exit 2
  }
  if [[ "$src" == "$project/scripts/chatgpt-browser-agent" ]]; then
    require_executable "$src"
    require_executable "$dest"
  fi
done

for spec in "${writable_specs[@]}"; do
  IFS='|' read -r src dest _mode group <<<"$spec"
  [[ -f "$src" ]] || {
    printf '%s\n' "AUTO_DEPLOY_FAILED missing source: $src"
    exit 2
  }
  if [[ "$group" == agent ]] && ! compare_files "$src" "$dest"; then
    agent_update_pending=1
  fi
done

if ((agent_update_pending)); then
  exec 8>"$state_root/browser-restart.lock"
  flock 8
  python3 "$project/scripts/check-browser-restart-safe.py" \
    "${PSEUDO_CODEX_CONSOLE_URL:-http://127.0.0.1:8090}" \
    "${PSEUDO_CODEX_DEPLOY_JOB_ID:-}"
fi

node --check "$project/app.js"
node --check "$project/check.js"
node --check "$project/deploy/verify-live.js"
python3 -m py_compile "$project/dispatcher/dispatcher.py"
bash -n "$project/scripts/chatgpt-browser-agent"
node --check "$project/agent/agent.js"
node --check "$project/agent/chatgpt.js"
node --check "$project/agent/ws-decode.js"
APP_PATH="$project/app.js" node "$project/check.js"

for spec in "${writable_specs[@]}"; do
  IFS='|' read -r src dest mode group <<<"$spec"
  if compare_files "$src" "$dest"; then
    continue
  fi
  backup_target "$dest"
  install_target "$src" "$dest" "$mode"
  copied_count=$((copied_count + 1))
  case "$group" in
    console) console_changed=1; app_deployed=1 ;;
    dispatcher) dispatcher_changed=1 ;;
    agent) agent_changed=1 ;;
  esac
done

if ((copied_count == 0)) && [[ "$current_revision" == "$deployed_revision" ]]; then
  trap - ERR
  printf '%s\n' 'AUTO_DEPLOY_NO_CHANGES'
  exit 0
fi

if ((agent_changed)); then
  systemctl --user restart chatgpt-browser-agent.service
  systemctl --user is-active chatgpt-browser-agent.service >/dev/null
fi

if ((dispatcher_changed)); then
  schedule_dispatcher_restart
fi

if ((console_changed)); then
  sudo -n /usr/bin/systemctl restart pseudo-codex-console.service
fi
sudo -n /usr/bin/systemctl is-active pseudo-codex-console.service >/dev/null

python3 - <<'PY'
import json
import time
import urllib.request

for _ in range(50):
    try:
        with urllib.request.urlopen("http://127.0.0.1:8090/health", timeout=2) as response:
            payload = json.load(response)
        if payload.get("status") == "ok":
            break
    except Exception:
        time.sleep(0.2)
else:
    raise SystemExit("health check failed")
PY

node "$validator_root/verify-live.js"

for spec in "${writable_specs[@]}"; do
  IFS='|' read -r src dest _mode _group <<<"$spec"
  compare_files "$src" "$dest"
done

printf '%s\n' "$current_revision" > "$revision_path"

trap - ERR
printf '%s\n' "AUTO_DEPLOY_OK copied=$copied_count revision=$current_revision dispatcher_restart=$dispatcher_restart_scheduled app_deployed=$app_deployed"
