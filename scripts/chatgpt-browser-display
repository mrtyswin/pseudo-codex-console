#!/usr/bin/env bash
set -Eeuo pipefail

export HOME=/home/ubuntu
export USER=ubuntu
export LOGNAME=ubuntu
export DISPLAY=:99
export XDG_RUNTIME_DIR=/run/chatgpt-browser-display
export XAUTHORITY="$XDG_RUNTIME_DIR/Xauthority"
export NO_AT_BRIDGE=1

declare -a child_pids=()

cleanup() {
  trap - EXIT INT TERM
  if ((${#child_pids[@]})); then
    kill "${child_pids[@]}" 2>/dev/null || true
    wait "${child_pids[@]}" 2>/dev/null || true
  fi
  if [[ -n "${DBUS_SESSION_BUS_PID:-}" ]]; then
    kill "$DBUS_SESSION_BUS_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

install -m 600 /dev/null "$XAUTHORITY"
xauth -f "$XAUTHORITY" add "$DISPLAY" . "$(mcookie)"

Xvfb "$DISPLAY" -screen 0 1440x900x24 -nolisten tcp -auth "$XAUTHORITY" &
child_pids+=("$!")

for _ in $(seq 1 50); do
  if xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
    break
  fi
  sleep 0.1
done
xdpyinfo -display "$DISPLAY" >/dev/null 2>&1

eval "$(dbus-launch --sh-syntax)"
export DBUS_SESSION_BUS_ADDRESS DBUS_SESSION_BUS_PID

openbox --sm-disable &
child_pids+=("$!")

xset -display "$DISPLAY" -dpms >/dev/null 2>&1 || true
xset -display "$DISPLAY" s off >/dev/null 2>&1 || true
xset -display "$DISPLAY" s noblank >/dev/null 2>&1 || true

x11vnc \
  -display "$DISPLAY" \
  -auth "$XAUTHORITY" \
  -localhost \
  -forever \
  -shared \
  -nopw \
  -rfbport 5900 \
  -noxdamage \
  -quiet &
child_pids+=("$!")

websockify \
  --web=/usr/share/novnc \
  127.0.0.1:6080 \
  127.0.0.1:5900 &
child_pids+=("$!")

wait -n "${child_pids[@]}"
