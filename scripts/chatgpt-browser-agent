#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "$(id -un)" != "ubuntu" ]]; then
  echo "Run this command as the ubuntu user." >&2
  exit 2
fi

repo="${CHATGPT_BROWSER_AGENT_HOME:-/home/ubuntu/chatgpt-browser-agent}"
export HOME=/home/ubuntu
export DISPLAY="${DISPLAY:-:99}"
export XAUTHORITY="${XAUTHORITY:-/run/chatgpt-browser-display/Xauthority}"

if [[ ! -f "$repo/chatgpt.js" || ! -f "$repo/agent.js" ]]; then
  echo "chatgpt-browser-agent is not installed at $repo" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  chatgpt-browser-agent login
  chatgpt-browser-agent ask [chatgpt.js options] "prompt"
  chatgpt-browser-agent run [agent.js options] "task"       # Ubuntu host-native
  chatgpt-browser-agent run-host [agent.js options] "task"  # compatibility alias
  chatgpt-browser-agent start
  chatgpt-browser-agent status
  chatgpt-browser-agent stop
EOF
}

command_name="${1:-}"
if (($#)); then
  shift
fi

case "$command_name" in
  login)
    exec node "$repo/chatgpt.js" --login "$@"
    ;;
  ask)
    exec node "$repo/chatgpt.js" "$@"
    ;;
  run|run-host)
    exec node "$repo/agent.js" "$@"
    ;;
  start)
    exec node "$repo/chatgpt.js" --start
    ;;
  status)
    exec node "$repo/chatgpt.js" --status
    ;;
  stop)
    exec node "$repo/chatgpt.js" --stop
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    echo "Unknown command: $command_name" >&2
    usage >&2
    exit 2
    ;;
esac
